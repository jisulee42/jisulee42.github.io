---
import { SITE_AUTHOR, SITE_TITLE } from '../consts';
import { withBase } from '../utils/path';

const year = new Date().getFullYear();
---

<footer>
	<div class="inner">
		<div>
			<strong>{SITE_TITLE}</strong>
			<p>콘텐츠 중심의 개인 기술 기록 공간입니다.</p>
		</div>
		<div class="links">
			<a href={withBase('/blog/')}>포스트</a>
			<a href={withBase('/about/')}>소개</a>
		</div>
	</div>
	<p class="copyright">© {year} {SITE_AUTHOR}. All rights reserved.</p>
</footer>

<style>
	footer {
		border-top: 1px solid rgb(var(--line));
		padding: 2rem 0 2.5rem;
		margin-top: 2rem;
	}

	.inner {
		width: min(1280px, calc(100% - 2rem));
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		gap: 1rem;
	}

	.inner p {
		margin: 0.35rem 0 0;
		color: rgb(var(--muted));
		font-size: 0.92rem;
	}

	.links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		justify-content: flex-end;
		align-content: flex-start;
	}

	.links a {
		font-size: 0.88rem;
		text-decoration: none;
		color: rgb(var(--muted));
	}

	.copyright {
		width: min(1280px, calc(100% - 2rem));
		margin: 1rem auto 0;
		font-size: 0.82rem;
		color: rgb(var(--muted));
	}

	@media (max-width: 760px) {
		.inner {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
		}

		.inner p {
			display: none;
		}
	}
</style>
