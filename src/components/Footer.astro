---
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { withBase } from '../utils/path';

const year = new Date().getFullYear();
---

<footer>
	<div class="inner">
		<div class="brand-col">
			<a class="brand" href={withBase('/')}>
				<span class="mark" aria-hidden="true">
					<svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
						<rect x="2.5" y="2.5" width="23" height="23" rx="5.5" stroke="currentColor" stroke-opacity="0.16" stroke-width="1.1"></rect>
						<path
							d="M9 8.5 L9 16.5 Q9 19.5 12 19.5 L18 19.5"
							stroke="currentColor"
							stroke-opacity="0.9"
							stroke-width="3.2"
							stroke-linecap="round"
							stroke-linejoin="round"
						></path>
						<circle cx="19" cy="9" r="3.6" fill="#e5484d"></circle>
					</svg>
				</span>
				<strong>{SITE_TITLE}</strong>
			</a>
			<p class="tagline">{SITE_DESCRIPTION}</p>
		</div>

		<nav class="links" aria-label="Footer navigation">
			<a href={withBase('/blog/')}>Posts</a>
			<a href={withBase('/about/')}>About</a>
			<a href={withBase('/rss.xml')}>RSS</a>
			<a href="https://github.com/jisulee42" target="_blank" rel="noopener noreferrer">GitHub</a>
		</nav>
	</div>

	<div class="bottom">
		<p class="copyright">© {year} {SITE_AUTHOR}. All rights reserved.</p>
		<a class="gh-link" href="https://github.com/jisulee42" target="_blank" rel="noopener noreferrer" aria-label="GitHub 프로필" title="GitHub">
			<svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor" aria-hidden="true">
				<path
					d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
				></path>
			</svg>
		</a>
	</div>
</footer>

<style>
	footer {
		margin-top: 4rem;
		border-top: 1px solid rgb(var(--line));
		background: rgb(var(--surface-strong));
	}

	.inner {
		width: min(1280px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 2.5rem 0 2rem;
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 2rem;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		text-decoration: none;
		color: rgb(var(--text));
	}

	.mark {
		display: inline-flex;
		color: rgb(var(--text));
	}

	.mark svg {
		width: 26px;
		height: 26px;
		display: block;
	}

	.brand strong {
		font-size: 0.95rem;
	}

	.tagline {
		margin: 0.7rem 0 0;
		max-width: 32ch;
		color: rgba(var(--muted), 0.65);
		font-size: 0.88rem;
		line-height: 1.6;
	}

	.links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.25rem 1.5rem;
		padding-top: 0.3rem;
	}

	.links a {
		font-size: 0.88rem;
		font-weight: 500;
		text-decoration: none;
		color: rgba(var(--muted), 0.7);
		line-height: 2;
		transition: color 0.15s ease;
	}

	.links a:hover {
		color: rgb(var(--accent));
	}

	.bottom {
		width: min(1280px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 1.1rem 0 1.4rem;
		border-top: 1px solid rgb(var(--line));
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
	}

	.copyright {
		margin: 0;
		font-size: 0.8rem;
		color: rgba(var(--muted), 0.55);
	}

	.gh-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		border-radius: 8px;
		color: rgba(var(--muted), 0.7);
		transition:
			color 0.15s ease,
			background 0.15s ease;
	}

	.gh-link:hover {
		color: rgb(var(--text));
		background: rgb(var(--surface));
	}

	@media (max-width: 760px) {
		.inner {
			flex-direction: column;
			gap: 1.4rem;
			padding: 2rem 0 1.6rem;
		}

		.links {
			padding-top: 0;
			gap: 0.25rem 1.25rem;
		}
	}
</style>
