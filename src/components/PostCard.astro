---
import type { CollectionEntry } from 'astro:content';
import { SITE_AUTHOR } from '../consts';
import { getCategoryStyle } from '../utils/category';
import { withBase } from '../utils/path';
import PostThumb from './PostThumb.astro';

interface Props {
	readonly post: CollectionEntry<'blog'>;
	readonly featured?: boolean;
}

const { post, featured = false } = Astro.props;
const categoryStyle = getCategoryStyle(post.data.category);
---

<article class:list={['post-card', { featured }]}>
	<a class="thumbnail" href={withBase(`/blog/${post.id}/`)}>
		<PostThumb post={post} />
	</a>
	<div class="content">
		<div class="meta-top">
			<a
				class="chip"
				style={`color:${categoryStyle.accent};background:${categoryStyle.soft}`}
				href={withBase(`/categories/${encodeURIComponent(post.data.category)}/`)}
			>
				{post.data.category}
			</a>
		</div>
		<p class="description">{post.data.description}</p>
		<div class="meta-bottom">
			<time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('ko-KR')}</time>
			<span aria-hidden="true">·</span>
			<span>{SITE_AUTHOR}</span>
		</div>
	</div>
</article>

<style>
	.post-card {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.thumbnail {
		display: block;
		border-radius: var(--radius-md);
		overflow: hidden;
		background: rgb(var(--surface-strong));
		aspect-ratio: 16 / 9;
	}

	.post-card:hover .thumbnail :global(.pt-img),
	.post-card:hover .thumbnail :global(.pt-auto) {
		transform: scale(1.02);
	}

	.meta-top {
		margin-bottom: 0.5rem;
	}

	.description {
		color: rgb(25, 31, 40);
		font-weight: 600;
		font-size: 0.96rem;
		line-height: 1.45;
		margin-bottom: 0.5rem;
		letter-spacing: -0.01em;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.meta-bottom {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		font-family: var(--font-mono);
		font-size: 0.74rem;
		color: rgba(var(--muted), 0.6);
	}

	.featured .description {
		-webkit-line-clamp: 3;
		font-size: 0.93rem;
	}
</style>
