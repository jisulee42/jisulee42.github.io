---
import HeaderLink from './HeaderLink.astro';
import { withBase } from '../utils/path';
---

<header>
	<div class="inner">
		<a class="brand" href={withBase('/')}>
			<span class="mark" aria-hidden="true">
				<svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
					<rect x="2.5" y="2.5" width="23" height="23" rx="5.5" stroke="currentColor" stroke-opacity="0.16" stroke-width="1.1"></rect>
					<path
						d="M9 8.5 L9 16.5 Q9 19.5 12 19.5 L18 19.5"
						stroke="currentColor"
						stroke-opacity="0.9"
						stroke-width="3.2"
						stroke-linecap="round"
						stroke-linejoin="round"
					></path>
					<circle cx="19" cy="9" r="3.6" fill="#e5484d"></circle>
				</svg>
			</span>
			<div>
				<strong>Tech Blog<span class="caret" aria-hidden="true"></span></strong>
			</div>
		</a>

		<div class="controls">
			<nav>
				<HeaderLink href="/blog/" class="text-link">Posts</HeaderLink>
				<HeaderLink href="/categories/" class="text-link">Categories</HeaderLink>
				<HeaderLink href="/about/" class="text-link">About</HeaderLink>
			</nav>
			<a class="gh-link" href="https://github.com/jisulee42" target="_blank" rel="noopener noreferrer" aria-label="GitHub 프로필" title="GitHub">
				<svg viewBox="0 0 16 16" width="28" height="28" fill="currentColor" aria-hidden="true">
					<path
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
					></path>
				</svg>
			</a>
		</div>
	</div>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 40;
		backdrop-filter: blur(10px);
		background: color-mix(in srgb, rgb(var(--surface)) 90%, transparent);
		border-bottom: 1px solid rgb(var(--line));
	}

	.inner {
		width: min(1280px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 0.75rem 0;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
	}

	.controls {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		margin-left: auto;
	}

	.gh-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		border-radius: 8px;
		color: rgb(var(--text));
		transition: background 0.15s ease;
	}

	.gh-link:hover {
		background: rgb(var(--surface-strong));
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		text-decoration: none;
	}

	.mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: rgb(var(--text));
	}

	.mark svg {
		width: 30px;
		height: 30px;
		display: block;
	}

	.brand strong {
		display: block;
		font-size: 0.98rem;
		line-height: 1.1;
	}

	.caret {
		display: inline-block;
		width: 0.5rem;
		height: 0.72em;
		margin-left: 0.12rem;
		vertical-align: baseline;
		background: rgb(var(--accent));
		border-radius: 1px;
		animation: caret-blink 1.1s steps(1) infinite;
	}

	@keyframes caret-blink {
		50% {
			opacity: 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.caret {
			animation: none;
		}
	}

	nav {
		display: flex;
		justify-content: flex-end;
		gap: 0.15rem;
	}

	@media (max-width: 880px) {
		.inner {
			flex-direction: row;
			align-items: center;
		}

		.controls {
			width: auto;
			justify-content: flex-end;
			margin-left: auto;
		}

		nav {
			justify-content: flex-end;
		}
	}

	@media (max-width: 540px) {
		.brand strong {
			font-size: 0.88rem;
		}

		.mark {
			width: 24px;
			height: 24px;
			font-size: 0.75rem;
		}
	}
</style>
