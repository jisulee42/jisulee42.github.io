---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getCategoryCounts, getPublishedPosts } from '../../utils/blog';
import { withBase } from '../../utils/path';

const allPosts = await getPublishedPosts();
const categories = [...getCategoryCounts(allPosts).entries()].sort((a, b) => b[1] - a[1]);
const total = allPosts.length;
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`Categories | ${SITE_TITLE}`} description="Browse all categories" />
		<style>
			.hero {
				border-top: 1px solid rgb(var(--line));
				border-bottom: 1px solid rgb(var(--line));
				background: rgb(238, 240, 244);
				overflow: hidden;
				position: relative;
			}

			.hero-inner {
				width: min(1280px, calc(100% - 2rem));
				margin: 0 auto;
				padding: 3rem 0 2.6rem;
				position: relative;
				z-index: 1;
			}

			.hero-deco {
				position: absolute;
				right: -0.5rem;
				top: 50%;
				transform: translateY(-50%);
				font-size: clamp(7rem, 14vw, 12rem);
				font-weight: 800;
				letter-spacing: -0.04em;
				color: rgba(var(--text), 0.04);
				font-style: italic;
				line-height: 1;
				user-select: none;
				pointer-events: none;
			}

			.crumb {
				font-family: var(--font-mono);
				font-size: 0.82rem;
				font-weight: 500;
				color: rgb(var(--accent));
			}

			.crumb .dim {
				color: rgba(var(--muted), 0.4);
			}

			.hero h1 {
				margin: 0.45rem 0 0.6rem;
				font-size: clamp(2rem, 3.5vw, 2.8rem);
				letter-spacing: -0.02em;
				display: block;
				width: fit-content;
				position: relative;
			}

			.hero h1::after {
				content: '';
				position: absolute;
				left: -4px;
				right: -4px;
				bottom: 0.06em;
				height: 0.36em;
				background: rgba(0, 0, 0, 0.09);
				border-radius: 4px;
			}

			.hero p {
				margin: 0;
				font-family: var(--font-mono);
				font-size: 0.82rem;
				color: rgba(var(--muted), 0.5);
			}

			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
				gap: 1rem;
				padding-top: 2rem;
			}

			@media (max-width: 760px) {
				.hero-deco {
					font-size: 6rem;
				}
			}

			.cat-card {
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				gap: 1.2rem;
				padding: 1.4rem 1.5rem;
				border: 1px solid rgb(var(--line));
				border-radius: var(--radius-md);
				text-decoration: none;
				color: rgb(var(--text));
				background: rgb(var(--surface));
				transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
			}

			.cat-card:hover {
				border-color: rgb(var(--accent));
				box-shadow: 0 4px 16px rgba(var(--accent), 0.1);
				background: rgb(var(--surface-strong));
			}

			.cat-name {
				font-size: 1.1rem;
				font-weight: 700;
				letter-spacing: -0.01em;
			}

			.cat-meta {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.5rem;
			}

			.cat-count {
				font-family: var(--font-mono);
				font-size: 0.72rem;
				font-weight: 500;
				color: rgba(var(--muted), 0.55);
			}

			.cat-bar-wrap {
				height: 3px;
				border-radius: 999px;
				background: rgb(var(--line));
				flex: 1;
				overflow: hidden;
			}

			.cat-bar {
				height: 100%;
				border-radius: 999px;
				background: rgb(var(--accent));
				transition: width 0.3s ease;
			}
		</style>
	</head>
	<body>
		<Header />

		<div class="hero">
			<div class="hero-inner">
				<div class="crumb" aria-hidden="true"><span class="dim">~/</span>categories</div>
				<h1>Categories</h1>
				<p>{categories.length} categories · {total} posts</p>
			</div>
			<span class="hero-deco" aria-hidden="true">Categories</span>
		</div>

		<main>
			<div class="grid">
				{
					categories.map(([name, count]) => (
						<a class="cat-card" href={withBase(`/categories/${encodeURIComponent(name)}/`)}>
							<span class="cat-name">#{name}</span>
							<div class="cat-meta">
								<div class="cat-bar-wrap">
									<div class="cat-bar" style={`width:${Math.round((count / total) * 100)}%`} />
								</div>
								<span class="cat-count">{count} posts</span>
							</div>
						</a>
					))
				}
			</div>
		</main>
		<Footer />
	</body>
</html>
