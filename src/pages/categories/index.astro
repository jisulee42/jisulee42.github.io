---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getCategoryCounts, getPublishedPosts } from '../../utils/blog';
import { withBase } from '../../utils/path';

const categories = [...getCategoryCounts(await getPublishedPosts()).entries()].sort((a, b) => b[1] - a[1]);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`카테고리 | ${SITE_TITLE}`} description="모든 카테고리를 확인하세요" />
		<style>
			.cloud {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<span class="chip chip-accent">CATEGORIES</span>
			<h1>카테고리</h1>
			<div class="cloud">
				{categories.map(([category, count]) => <a class="chip" href={withBase(`/categories/${encodeURIComponent(category)}/`)}>#{category} ({count})</a>)}
			</div>
		</main>
		<Footer />
	</body>
</html>
