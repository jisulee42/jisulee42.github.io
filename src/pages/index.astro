---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PostThumb from '../components/PostThumb.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCategoryCounts, getPublishedPosts } from '../utils/blog';
import { getCategoryStyle } from '../utils/category';
import { withBase } from '../utils/path';

const [posts, seriesEntries] = await Promise.all([getPublishedPosts(), getCollection('series')]);
const featuredPosts = posts.slice(0, 10);
const listPosts = posts;

const categoryItems = Array.from(getCategoryCounts(posts).entries())
	.map(([name, count]) => ({ name, count, style: getCategoryStyle(name) }))
	.sort((a, b) => b.count - a.count || a.name.localeCompare(b.name, 'ko'));

const seriesItems = seriesEntries
	.map((series) => ({
		id: series.id,
		title: series.data.title,
		description: series.data.description,
		count: listPosts.filter((post) => post.data.series?.id === series.id).length,
	}))
	.filter((series) => series.count > 0)
	.sort((a, b) => b.count - a.count || a.title.localeCompare(b.title, 'ko'));

---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			:global(body.home-page) {
				overflow-x: hidden;
			}

			.section {
				margin-top: 2.6rem;
			}

			.section > h2,
			.recent-head h2 {
				color: rgb(25, 31, 40);
				font-weight: 700;
				font-size: 1.3rem;
				letter-spacing: -0.02em;
				display: block;
				width: fit-content;
				position: relative;
			}

			.section > h2 { margin-bottom: 1.15rem; }
			.recent-head h2 { margin: 0; }

			.section > h2::after,
			.recent-head h2::after {
				content: '';
				position: absolute;
				left: -3px;
				right: -3px;
				bottom: 0.05em;
				height: 0.36em;
				background: rgba(0, 0, 0, 0.09);
				border-radius: 3px;
			}

			.section > h2::before,
			.recent-head h2::before {
				content: '#';
				margin-right: 0.4rem;
				font-family: var(--font-mono);
				font-weight: 700;
				color: rgb(var(--accent));
			}

			.recent-head {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 1.15rem;
			}

			.carousel-nav {
				display: flex;
				gap: 0.5rem;
			}

			.carousel-arrow {
				width: 38px;
				height: 38px;
				border-radius: 999px;
				border: none;
				background: rgb(255, 255, 255);
				color: rgb(78, 89, 104);
				font-size: 1.2rem;
				line-height: 1;
				cursor: pointer;
				display: inline-flex;
				align-items: center;
				justify-content: center;
				box-shadow: 0 2px 8px rgba(15, 23, 42, 0.12), 0 0 0 1px rgba(15, 23, 42, 0.04);
				transition: background 0.15s ease, transform 0.12s ease, box-shadow 0.15s ease, opacity 0.15s ease;
			}

			.carousel-arrow:hover {
				background: rgb(249, 250, 251);
				box-shadow: 0 4px 14px rgba(15, 23, 42, 0.16), 0 0 0 1px rgba(15, 23, 42, 0.05);
			}

			.carousel-arrow:active {
				transform: scale(0.92);
			}

			.carousel-arrow:disabled {
				opacity: 0.32;
				cursor: default;
				box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.06);
			}

			.carousel-viewport {
				overflow: hidden;
			}

			.carousel-track {
				display: flex;
				transition: transform 0.75s cubic-bezier(0.45, 0, 0.25, 1);
				will-change: transform;
			}

			.hero-card {
				flex: 0 0 100%;
				display: grid;
				grid-template-columns: 1.25fr 1fr;
				border: 1px solid rgb(238, 240, 243);
				border-radius: 20px;
				overflow: hidden;
				background: rgb(255, 255, 255);
				text-decoration: none;
				box-shadow: 0 6px 24px rgba(15, 23, 42, 0.06);
				transition: box-shadow 0.25s ease;
			}

			.hero-card:hover {
				box-shadow: 0 14px 36px rgba(15, 23, 42, 0.12);
			}

			.hero-card-thumb {
				overflow: hidden;
				background: rgb(var(--surface-strong));
				min-height: 300px;
			}

			.hero-card:hover .hero-card-thumb :global(.pt-img),
			.hero-card:hover .hero-card-thumb :global(.pt-auto) {
				transform: scale(1.04);
			}

			.hero-card-body {
				display: flex;
				flex-direction: column;
				justify-content: center;
				padding: 2.2rem 2.4rem;
			}

			.hero-card-cat {
				font-size: 0.8rem;
				font-weight: 700;
				color: rgb(var(--accent));
				margin-bottom: 0.7rem;
			}

			.hero-card-title {
				font-size: 1.55rem;
				font-weight: 800;
				line-height: 1.3;
				letter-spacing: -0.02em;
				color: rgb(25, 31, 40);
				margin-bottom: 0.7rem;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.hero-card-desc {
				font-size: 0.92rem;
				line-height: 1.6;
				color: rgb(110, 118, 128);
				margin-bottom: 1.1rem;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.hero-card-date {
				font-size: 0.8rem;
				color: rgb(140, 148, 158);
			}

			.carousel-dots {
				display: flex;
				justify-content: center;
				gap: 0.45rem;
				margin-top: 1.1rem;
			}

			.carousel-dot {
				width: 8px;
				height: 8px;
				padding: 0;
				border: none;
				border-radius: 999px;
				background: rgb(214, 218, 223);
				cursor: pointer;
				transition: width 0.25s ease, background 0.25s ease;
			}

			.carousel-dot.active {
				width: 22px;
				background: rgb(var(--accent));
			}

			.category-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
				gap: 0.9rem;
			}

			.category-card {
				position: relative;
				display: flex;
				flex-direction: column;
				justify-content: flex-end;
				gap: 0.25rem;
				min-height: 96px;
				padding: 1.1rem 1.2rem;
				border-radius: 16px;
				overflow: hidden;
				text-decoration: none;
				color: rgb(255, 255, 255);
				background: linear-gradient(135deg, var(--from), var(--to));
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}

			.category-card::before {
				content: '';
				position: absolute;
				right: -30px;
				top: -30px;
				width: 110px;
				height: 110px;
				border-radius: 50%;
				background: rgba(255, 255, 255, 0.14);
			}

			.category-card:hover {
				transform: translateY(-3px);
				box-shadow: 0 12px 26px rgba(15, 23, 42, 0.18);
			}

			.category-name {
				position: relative;
				font-size: 1.05rem;
				font-weight: 800;
				letter-spacing: -0.01em;
			}

			.category-count {
				position: relative;
				font-size: 0.78rem;
				opacity: 0.88;
			}

			.all-layout {
				display: grid;
				grid-template-columns: minmax(0, 1fr) 280px;
				gap: 1.2rem;
			}

			.post-list {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1.1rem;
			}

			.list-card {
				display: flex;
				flex-direction: column;
				border: 1px solid rgb(238, 240, 243);
				background: rgb(255, 255, 255);
				border-radius: 16px;
				overflow: hidden;
				text-decoration: none;
				transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
			}

			.list-card:hover {
				border-color: transparent;
				box-shadow: 0 12px 30px rgba(15, 23, 42, 0.12);
				transform: translateY(-4px);
			}

			.list-body {
				display: block;
				padding: 1rem 1.1rem 1.2rem;
			}

			.list-cat {
				display: inline-block;
				font-size: 0.72rem;
				font-weight: 700;
				padding: 0.16rem 0.5rem;
				border-radius: 999px;
				margin-bottom: 0.55rem;
			}

			.list-thumb {
				overflow: hidden;
				background: rgb(var(--surface-strong));
				aspect-ratio: 16 / 10;
			}

			.list-card:hover .list-thumb :global(.pt-img),
			.list-card:hover .list-thumb :global(.pt-auto) {
				transform: scale(1.04);
			}

			.list-desc {
				font-size: 0.9rem;
				font-weight: 500;
				line-height: 1.5;
				color: rgb(75, 85, 99);
				margin-bottom: 0.55rem;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.list-date {
				font-size: 0.78rem;
				color: rgb(140, 148, 158);
			}

			.tag-panel {
				border: 1px solid rgb(var(--line));
				background: rgb(var(--surface));
				border-radius: var(--radius-md);
				padding: 1rem;
				height: fit-content;
				position: sticky;
				top: 92px;
			}

			.tag-panel h3 {
				font-size: 0.95rem;
				margin-bottom: 0.7rem;
			}

			.panel-tabs {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 0.45rem;
				margin-bottom: 0.75rem;
			}

			.panel-tab {
				border: 1px solid rgb(233, 236, 240);
				background: rgb(246, 247, 249);
				border-radius: 999px;
				padding: 0.24rem 0.58rem;
				font-size: 0.74rem;
				font-weight: 600;
				color: rgba(6, 11, 17, 0.48);
				cursor: pointer;
			}

			.panel-tab.active {
				background: rgba(var(--accent), 0.08);
				border-color: rgba(var(--accent), 0.2);
				color: rgb(var(--accent));
			}

			.panel-body[hidden] {
				display: none;
			}

			.panel-body {
				min-width: 0;
			}

			.tag-cloud {
				display: flex;
				flex-wrap: wrap;
				gap: 0.45rem;
			}

			.series-list {
				display: grid;
				gap: 0.5rem;
				min-width: 0;
				width: 100%;
			}

			.series-link {
				display: block;
				text-decoration: none;
				border: 1px solid rgb(var(--line));
				background: rgb(var(--surface));
				border-radius: 12px;
				padding: 0.55rem 0.65rem;
				width: 100%;
				max-width: 100%;
				overflow: hidden;
			}

			.series-link strong {
				display: block;
				font-size: 0.84rem;
				line-height: 1.3;
				margin-bottom: 0.18rem;
			}

			.series-link .series-desc {
				display: block;
				font-size: 0.74rem;
				color: rgba(6, 11, 17, 0.48);
				line-height: 1.35;
				margin-bottom: 0.24rem;
				overflow: hidden;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
			}

			.series-link .series-count {
				display: block;
				font-size: 0.72rem;
				color: rgba(6, 11, 17, 0.48);
			}

			@media (max-width: 1100px) {
				.all-layout {
					grid-template-columns: 1fr;
				}

				.tag-panel {
					position: static;
				}
			}

			@media (max-width: 900px) {
				.hero-card {
					grid-template-columns: 1fr;
				}

				.hero-card-thumb :global(img) {
					min-height: 200px;
				}

				.hero-card-body {
					padding: 1.4rem 1.5rem;
				}

				.hero-card-title {
					font-size: 1.3rem;
				}

				.post-list {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body class="home-page">
		<Header />
		<main>
			<section class="section recent-section">
				<div class="recent-head">
					<h2>최근 올라온 글</h2>
					<div class="carousel-nav">
						<button class="carousel-arrow" type="button" data-dir="prev" aria-label="이전 글">‹</button>
						<button class="carousel-arrow" type="button" data-dir="next" aria-label="다음 글">›</button>
					</div>
				</div>
				<div class="carousel-viewport" id="recent-viewport">
					<div class="carousel-track" id="recent-track">
						{
							featuredPosts.map((post) => (
								<a class="hero-card" href={withBase(`/blog/${post.id}/`)}>
									<span class="hero-card-thumb">
										<PostThumb post={post} showTitle={false} />
									</span>
									<span class="hero-card-body">
										<span class="hero-card-cat" style={`color:${getCategoryStyle(post.data.category).accent}`}>
											{post.data.category}
										</span>
										<strong class="hero-card-title">{post.data.title}</strong>
										<span class="hero-card-desc">{post.data.description}</span>
										<span class="hero-card-date">{post.data.pubDate.toLocaleDateString('ko-KR')}</span>
									</span>
								</a>
							))
						}
					</div>
				</div>
				<div class="carousel-dots" id="recent-dots">
					{
						featuredPosts.map((_, index) => (
							<button class="carousel-dot" type="button" data-idx={index} aria-label={`${index + 1}번째 글로 이동`} />
						))
					}
				</div>
			</section>

			<section class="section">
				<h2>카테고리</h2>
				<div class="category-grid">
					{
						categoryItems.map((item) => (
							<a
								class="category-card"
								href={withBase(`/categories/${encodeURIComponent(item.name)}/`)}
								style={`--from:${item.style.from};--to:${item.style.to}`}
							>
								<span class="category-name">{item.name}</span>
								<span class="category-count">{item.count}개 글</span>
							</a>
						))
					}
				</div>
			</section>

			<section class="section">
				<h2>전체 게시글</h2>
				<div class="all-layout">
					<div>
						<div class="post-list" id="post-list">
							{
								listPosts.map((post) => (
									<a class="list-card" href={withBase(`/blog/${post.id}/`)}>
										<span class="list-thumb">
											<PostThumb post={post} />
										</span>
										<span class="list-body">
											<span
												class="list-cat"
												style={`color:${getCategoryStyle(post.data.category).accent};background:${getCategoryStyle(post.data.category).soft}`}
											>
												{post.data.category}
											</span>
											<span class="list-desc">{post.data.description}</span>
											<span class="list-date">{post.data.pubDate.toLocaleDateString('ko-KR')}</span>
										</span>
									</a>
								))
							}
						</div>
					</div>

					<aside class="tag-panel">
						<div class="panel-tabs" role="tablist" aria-label="사이드 패널 전환">
							<button class="panel-tab active" type="button" data-panel-tab="tags" role="tab" aria-selected="true">Tag</button>
							<button class="panel-tab" type="button" data-panel-tab="series" role="tab" aria-selected="false">Series</button>
						</div>

						<div data-panel-body="tags" role="tabpanel">
							<h3>Tag</h3>
							<div class="tag-cloud">
								{
									Array.from(new Set(posts.flatMap((post) => post.data.tags))).slice(0, 18).map((tag) => (
										<a class="chip" href={withBase(`/tags/${encodeURIComponent(tag)}/`)}>#{tag}</a>
									))
								}
							</div>
						</div>

						<div data-panel-body="series" role="tabpanel" hidden>
							<h3>Series</h3>
							<div class="series-list">
							{
								seriesItems.map((series) => (
									<a class="series-link" href={withBase(`/series/${series.id}/`)}>
										<strong>{series.title}</strong>
										<span class="series-desc">{series.description}</span>
										<span class="series-count">{series.count}개 글</span>
									</a>
								))
							}
							</div>
						</div>
					</aside>
				</div>
			</section>
		</main>
		<Footer />

		<script is:inline>
			(() => {
				const panelTabs = Array.from(document.querySelectorAll('[data-panel-tab]'));
				const panelBodies = Array.from(document.querySelectorAll('[data-panel-body]'));

				panelTabs.forEach((button) => {
					button.addEventListener('click', () => {
						const target = button.getAttribute('data-panel-tab');
						if (!target) {
							return;
						}

						panelTabs.forEach((tab) => {
							const isActive = tab === button;
							tab.classList.toggle('active', isActive);
							tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
						});

						panelBodies.forEach((panel) => {
							panel.hidden = panel.getAttribute('data-panel-body') !== target;
						});
					});
				});
			})();
		</script>

		<script is:inline>
			(() => {
				const track = document.getElementById('recent-track');
				const viewport = document.getElementById('recent-viewport');
				if (!track || !viewport) {
					return;
				}
				const prevBtn = document.querySelector('.carousel-arrow[data-dir="prev"]');
				const nextBtn = document.querySelector('.carousel-arrow[data-dir="next"]');
				const dots = Array.from(document.querySelectorAll('.carousel-dot'));
				const slides = track.children.length;

				let index = 0;
				let timer = 0;

				const slideW = () => viewport.clientWidth;

				const apply = (animate = true) => {
					track.style.transition = animate ? '' : 'none';
					track.style.transform = `translateX(${-index * slideW()}px)`;
					if (prevBtn) {
						prevBtn.disabled = index <= 0;
					}
					if (nextBtn) {
						nextBtn.disabled = index >= slides - 1;
					}
					dots.forEach((dot, i) => dot.classList.toggle('active', i === index));
				};

				const go = (i) => {
					index = Math.max(0, Math.min(slides - 1, i));
					apply();
				};

				const tick = () => {
					index = (index + 1) % slides;
					apply();
				};
				const startAuto = () => {
					if (slides > 1 && !timer) {
						timer = window.setInterval(tick, 5000);
					}
				};
				const stopAuto = () => {
					if (timer) {
						window.clearInterval(timer);
						timer = 0;
					}
				};
				const restart = () => {
					stopAuto();
					startAuto();
				};

				if (prevBtn) {
					prevBtn.addEventListener('click', () => {
						go(index - 1);
						restart();
					});
				}
				if (nextBtn) {
					nextBtn.addEventListener('click', () => {
						go(index + 1);
						restart();
					});
				}
				dots.forEach((dot, i) => {
					dot.addEventListener('click', () => {
						go(i);
						restart();
					});
				});

				viewport.addEventListener('mouseenter', stopAuto);
				viewport.addEventListener('mouseleave', startAuto);
				document.addEventListener('visibilitychange', () => {
					if (document.hidden) {
						stopAuto();
					} else {
						startAuto();
					}
				});

				window.addEventListener('resize', () => apply(false));

				apply(false);
				startAuto();
			})();
		</script>

	</body>
</html>
