---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { withBase } from '../utils/path';

const topics = ['Backend', 'Architecture', 'Infra', 'DevOps', 'Tooling', 'TIL'];
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description="About this blog" />
		<style>
			.hero {
				border-top: 1px solid rgb(var(--line));
				border-bottom: 1px solid rgb(var(--line));
				background: rgb(238, 240, 244);
				overflow: hidden;
				position: relative;
			}

			.hero-inner {
				width: min(1280px, calc(100% - 2rem));
				margin: 0 auto;
				padding: 3rem 0 2.6rem;
				min-height: 217px;
				box-sizing: border-box;
				position: relative;
				z-index: 1;
			}

			.hero-deco {
				position: absolute;
				right: -0.5rem;
				top: 50%;
				transform: translateY(-50%);
				font-size: clamp(7rem, 14vw, 12rem);
				font-weight: 800;
				letter-spacing: -0.04em;
				color: rgba(var(--text), 0.04);
				font-style: italic;
				line-height: 1;
				user-select: none;
				pointer-events: none;
			}

			.crumb {
				font-family: var(--font-mono);
				font-size: 0.82rem;
				font-weight: 500;
				color: rgb(var(--accent));
			}

			.crumb .dim {
				color: rgba(var(--muted), 0.4);
			}

			.hero h1 {
				margin: 0.45rem 0 0;
				font-size: clamp(2rem, 3.5vw, 2.8rem);
				letter-spacing: -0.02em;
				display: block;
				width: fit-content;
				position: relative;
			}

			.hero h1::after {
				content: '';
				position: absolute;
				left: -4px;
				right: -4px;
				bottom: 0.06em;
				height: 0.36em;
				background: rgba(0, 0, 0, 0.09);
				border-radius: 4px;
			}

			.content {
				max-width: 720px;
				padding-top: 2.6rem;
				padding-bottom: 1rem;
			}

			.lead {
				font-size: 1.08rem;
				line-height: 1.85;
				color: rgba(var(--text), 0.82);
			}

			.about-section {
				margin-top: 2.8rem;
			}

			.about-section h2 {
				font-size: 1.15rem;
				font-weight: 700;
				letter-spacing: -0.02em;
				margin-bottom: 0.9rem;
			}

			.about-section h2::before {
				content: '#';
				margin-right: 0.4rem;
				font-family: var(--font-mono);
				font-weight: 700;
				color: rgb(var(--accent));
			}

			.about-section p {
				font-size: 1rem;
				line-height: 1.8;
				color: rgba(var(--text), 0.78);
				margin: 0;
			}

			.write-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 0.55rem;
			}

			.write-list li {
				position: relative;
				padding-left: 1.4rem;
				font-size: 1rem;
				line-height: 1.7;
				color: rgba(var(--text), 0.78);
			}

			.write-list li::before {
				content: '→';
				position: absolute;
				left: 0;
				color: rgb(var(--accent));
				font-family: var(--font-mono);
			}

			.topics {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
			}

			.links {
				display: flex;
				flex-wrap: wrap;
				gap: 0.7rem;
			}

			.link-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.45rem;
				padding: 0.5rem 0.9rem;
				border: 1px solid rgb(var(--line));
				border-radius: var(--radius-md);
				font-family: var(--font-mono);
				font-size: 0.84rem;
				color: rgb(var(--text));
				text-decoration: none;
				background: rgb(var(--surface));
				transition: border-color 0.15s ease, background 0.15s ease;
			}

			.link-btn:hover {
				border-color: rgb(var(--accent));
				background: rgb(var(--surface-strong));
			}

			.link-btn svg {
				width: 16px;
				height: 16px;
				fill: currentColor;
			}

			@media (max-width: 760px) {
				.hero-deco {
					font-size: 6rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />

		<div class="hero">
			<div class="hero-inner">
				<div class="crumb" aria-hidden="true"><span class="dim">~/</span>about</div>
				<h1>About</h1>
			</div>
			<span class="hero-deco" aria-hidden="true">About</span>
		</div>

		<main>
			<div class="content">
				<p class="lead">
					실무에서 부딪힌 문제와 그 해결 과정을 기록하는 개인 기술 블로그입니다. 검색으로는 찾기 어려웠던 맥락,
					선택의 트레이드오프, 그리고 6개월 뒤의 나에게 도움이 될 메모를 남깁니다.
				</p>

				<section class="about-section">
					<h2>무엇을 쓰나요</h2>
					<ul class="write-list">
						<li>아키텍처 의사결정과 그 배경, 그리고 시간이 지나서 본 결과</li>
						<li>백엔드·인프라를 운영하며 얻은 교훈과 장애 회고</li>
						<li>개발 생산성을 높이는 도구와 워크플로 세팅</li>
						<li>그날그날 짧게 배운 것(TIL)</li>
					</ul>
				</section>

				<section class="about-section">
					<h2>주로 다루는 주제</h2>
					<div class="topics">
						{topics.map((topic) => <span class="chip">{topic}</span>)}
					</div>
				</section>

				<section class="about-section">
					<h2>연락 &amp; 구독</h2>
					<p style="margin-bottom: 1rem;">새 글은 RSS로 구독할 수 있고, 코드와 작업물은 GitHub에서 볼 수 있습니다.</p>
					<div class="links">
						<a class="link-btn" href="https://github.com/jisulee42" target="_blank" rel="noopener noreferrer">
							<svg viewBox="0 0 16 16" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z"></path></svg>
							github
						</a>
						<a class="link-btn" href={withBase('/rss.xml')}>
							<svg viewBox="0 0 16 16" aria-hidden="true"><path d="M2 11a3 3 0 0 1 3 3H2v-3Zm0-4.5c3.59 0 6.5 2.91 6.5 6.5H6.5A4.5 4.5 0 0 0 2 8.5V6.5Zm0-4C7.52 2.5 12 6.98 12 12.5h-2C10 8.08 6.42 4.5 2 4.5v-2Z"></path></svg>
							rss
						</a>
					</div>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>
